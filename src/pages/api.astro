---
import DocLayout from '../layouts/DocLayout.astro';
---
<DocLayout title="API Reference — Autional Docs">
  <h1 class="text-3xl font-bold mb-6">API Reference</h1>
  <p class="mb-6 text-neutral-600 dark:text-neutral-300">All 24 microservices have OpenAPI 3.0 specifications. Browse the interactive docs via the gateway, or download the raw specs from GitHub.</p>
  <h2 class="text-xl font-bold mt-8 mb-3">Interactive API Docs</h2>
  <pre class="rounded-xl bg-slate-900 text-green-400 p-4 text-sm overflow-x-auto mb-6">http://localhost:11080/docs/</pre>
  <h2 class="text-xl font-bold mt-8 mb-3">Key Endpoints</h2>
  <table class="w-full text-sm mt-4 border-collapse">
    <thead><tr class="border-b border-neutral-200"><th class="text-left font-medium py-2">Service</th><th class="text-left font-medium py-2">Port</th><th class="text-left font-medium py-2">Base Path</th></tr></thead>
    <tbody>
      <tr class="border-b border-neutral-100"><td class="py-2">Gateway</td><td class="py-2 font-mono">11080</td><td class="py-2 font-mono">/bff/&#123;service&#125;/api/v1/</td></tr>
      <tr class="border-b border-neutral-100"><td class="py-2">Identity</td><td class="py-2 font-mono">11001</td><td class="py-2 font-mono">/api/v1/auth/</td></tr>
      <tr class="border-b border-neutral-100"><td class="py-2">MFA</td><td class="py-2 font-mono">11005</td><td class="py-2 font-mono">/api/v1/mfa/</td></tr>
      <tr class="border-b border-neutral-100"><td class="py-2">OAuth</td><td class="py-2 font-mono">11006</td><td class="py-2 font-mono">/oauth/</td></tr>
      <tr class="border-b border-neutral-100"><td class="py-2">Tenant</td><td class="py-2 font-mono">11003</td><td class="py-2 font-mono">/api/v1/tenants/</td></tr>
      <tr class="border-b border-neutral-100"><td class="py-2">Session</td><td class="py-2 font-mono">11004</td><td class="py-2 font-mono">/api/v1/sessions/</td></tr>
      <tr class="border-b border-neutral-100"><td class="py-2">Audit</td><td class="py-2 font-mono">11013</td><td class="py-2 font-mono">/api/v1/audit-logs/</td></tr>
      <tr><td class="py-2">RBAC</td><td class="py-2 font-mono">11025</td><td class="py-2 font-mono">/api/v1/admin/roles</td></tr>
    </tbody>
  </table>
  <h2 class="text-xl font-bold mt-8 mb-3">Spec Files</h2>
  <pre class="rounded-xl bg-slate-900 text-green-400 p-4 text-sm overflow-x-auto">https://github.com/autional/authms/tree/main/docker/specs</pre>
</DocLayout>
