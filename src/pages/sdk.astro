---
import DocLayout from '../layouts/DocLayout.astro';
const reactCode = `import { AuthProvider } from '@autional/react';

function App() {
  return (
    <AuthProvider>
      <YourApp />
    </AuthProvider>
  );
}`;
const vueCode = `import { createApp } from 'vue';
import AutionalPlugin from '@autional/vue';

const app = createApp(App);
app.use(AutionalPlugin);
app.mount('#app');`;
const nodeCode = `import { verifyToken } from '@autional/node';

app.use(async (req, res, next) => {
  const user = await verifyToken(req);
  req.user = user;
  next();
});`;
---
<DocLayout title="SDK — Autional Docs">
  <h1 class="text-3xl font-bold mb-6">SDK</h1>
  <p class="mb-6 text-neutral-600 dark:text-neutral-300">30+ packages covering React, Vue, Next.js, Node.js, and 19 auto-generated API clients.</p>
  <h2 class="text-xl font-bold mt-8 mb-3">React</h2>
  <pre class="rounded-xl bg-slate-900 text-green-400 p-4 text-sm overflow-x-auto mb-6">npm install @autional/react @autional/core</pre>
  <p class="mb-4 text-neutral-600">Provider component that wraps your app with authentication context:</p>
  <pre class="rounded-xl bg-slate-900 p-4 text-sm overflow-x-auto mb-6"><code>{reactCode}</code></pre>
  <h2 class="text-xl font-bold mt-8 mb-3">Vue</h2>
  <pre class="rounded-xl bg-slate-900 text-green-400 p-4 text-sm overflow-x-auto mb-6">npm install @autional/vue @autional/core</pre>
  <pre class="rounded-xl bg-slate-900 p-4 text-sm overflow-x-auto mb-6"><code>{vueCode}</code></pre>
  <h2 class="text-xl font-bold mt-8 mb-3">Node.js</h2>
  <pre class="rounded-xl bg-slate-900 text-green-400 p-4 text-sm overflow-x-auto mb-6">npm install @autional/node</pre>
  <pre class="rounded-xl bg-slate-900 p-4 text-sm overflow-x-auto mb-6"><code>{nodeCode}</code></pre>
  <h2 class="text-xl font-bold mt-8 mb-3">All Packages</h2>
  <p class="mb-4 text-neutral-600">Browse the full SDK catalog at <a href="https://www.autional.com/sdk" class="text-primary-600 underline">www.autional.com/sdk</a> or the source on GitHub.</p>
</DocLayout>
